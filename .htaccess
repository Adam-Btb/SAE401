# ── Upload limits ────────────────────────────────────────────
php_value upload_max_filesize 10M
php_value post_max_size 12M
php_value max_execution_time 60
php_value memory_limit 128M

# ── Security : block direct execution of uploaded files ───────
<FilesMatch "\.(php|php5|phtml|phar)$">
    <IfModule mod_rewrite.c>
        RewriteEngine On
        RewriteCond %{REQUEST_URI} ^/img/uploads/
        RewriteRule .* - [F,L]
    </IfModule>
</FilesMatch>

# ── Pretty URLs (optional, already handled by index.php) ──────
Options -Indexes
